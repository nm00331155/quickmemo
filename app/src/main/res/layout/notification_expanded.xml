<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/notification_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textColor="@android:color/primary_text_light"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_todo_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="4dp"
        android:textColor="@android:color/primary_text_light"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_todo_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="4dp"
        android:textColor="@android:color/primary_text_light"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_todo_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="4dp"
        android:textColor="@android:color/primary_text_light"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_todo_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="4dp"
        android:textColor="@android:color/primary_text_light"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_todo_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="4dp"
        android:textColor="@android:color/primary_text_light"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_pinned_memo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingTop="6dp"
        android:textColor="@android:color/secondary_text_light"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/notification_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:paddingTop="6dp"
        android:textColor="#2A6BC8"
        android:textSize="12sp" />

</LinearLayout>
